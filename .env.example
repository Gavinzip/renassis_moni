# Renaiss Market Monitor Configuration

# Discord Webhook URL (Required for alerts)
DISCORD_WEBHOOK_URL="your_discord_webhook_url_here"

# 30-day rolling window for price calculation (Default: 30)
WINDOW_DAYS=30

# Price difference threshold to trigger alert ($ USD) (Default: 20)
PRICE_THRESHOLD=20.0

# Optional: AI API Keys (Used by market_report_vision.py if needed)
# OPENAI_API_KEY="your_openai_key"
# MINIMAX_API_KEY="your_minimax_key"
